{
  "name": "paint",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4000 --turbopack",
    "dev:terminal": "bun run src/server/terminal-server.ts",
    "dev:all": "bun run src/server/terminal-server.ts & bun run src/bridge/server.ts & next dev --port 4000 --turbopack",
    "bridge": "bun run src/bridge/server.ts",
    "build": "next build",
    "start": "next start --port 4000",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "next": "16.1.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "^1.3.9",
    "@types/node": "25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "4.2.1",
    "typescript": "^5.9.3"
  }
}
