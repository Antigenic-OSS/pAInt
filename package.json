{
  "name": "@antigenic-oss/paint",
  "version": "0.3.4",
  "description": "Visual editor for localhost web projects with a global paint CLI",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Antigenic-OSS/pAInt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Antigenic-OSS/pAInt.git"
  },
  "bugs": {
    "url": "https://github.com/Antigenic-OSS/pAInt/issues"
  },
  "keywords": [
    "paint",
    "pAInt",
    "visual-editor",
    "nextjs",
    "css",
    "localhost",
    "bridge-server",
    "terminal",
    "claude-code",
    "ai-coding",
    "developer-tools"
  ],
  "bin": {
    "paint": "bin/paint.js"
  },
  "files": [
    "bin",
    "public",
    "src",
    "next-env.d.ts",
    "next.config.mjs",
    "postcss.config.mjs",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "next dev --port 4000 --turbopack",
    "dev:terminal": "node ./bin/terminal-server.js",
    "dev:all": "node ./bin/terminal-server.js & node ./bin/bridge-server.js & next dev --port 4000 --turbopack",
    "bridge": "node ./bin/bridge-server.js",
    "postinstall": "node ./bin/postinstall.js",
    "build": "next build --webpack",
    "start": "next start --port 4000",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "smoke:packed-global": "node ./bin/smoke-packed-global.js",
    "prepublishOnly": "npm run smoke:packed-global"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "next": "16.1.6",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "4.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "ws": "^8.18.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5"
  }
}
