{
  "name": "paint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4000 --turbopack",
    "dev:terminal": "bun run src/server/terminal-server.ts",
    "dev:all": "bun run src/server/terminal-server.ts & bun run src/bridge/server.ts & next dev --port 4000 --turbopack",
    "bridge": "bun run src/bridge/server.ts",
    "build": "next build",
    "start": "next start --port 4000",
    "lint": "next lint"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "next": "^15.1.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
